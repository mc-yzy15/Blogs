.stats-container
  style.
    .stats-container{max-width:1200px;margin:0 auto;padding:20px 0}
    .stats-overview{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;margin-bottom:40px}
    .stat-card{background:var(--card-bg,#fff);border-radius:12px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.08);transition:transform .2s,box-shadow .2s;border:1px solid var(--card-border,#eee)}
    .stat-card:hover{transform:translateY(-2px);box-shadow:0 4px 20px rgba(0,0,0,.12)}
    .stat-card .stat-icon{font-size:32px;margin-bottom:12px}
    .stat-card .stat-value{font-size:28px;font-weight:700;color:var(--text-color,#333);margin-bottom:4px}
    .stat-card .stat-label{font-size:14px;color:var(--text-secondary,#999)}
    .stat-card.pv .stat-icon{color:#49b1f5}
    .stat-card.uv .stat-icon{color:#3eb489}
    .stat-card.posts .stat-icon{color:#f5a623}
    .stat-card.cats .stat-icon{color:#ff6b6b}
    .stats-section{background:var(--card-bg,#fff);border-radius:12px;padding:28px;margin-bottom:30px;box-shadow:0 2px 12px rgba(0,0,0,.08);border:1px solid var(--card-border,#eee)}
    .stats-section-title{font-size:20px;font-weight:700;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid #49b1f5;color:var(--text-color,#333);display:flex;align-items:center;gap:8px}
    .stats-section-title i{color:#49b1f5}
    .cat-chart-area{display:flex;gap:30px;align-items:flex-start;flex-wrap:wrap}
    .cat-bar-chart{flex:1;min-width:300px}
    .cat-bar-item{margin-bottom:14px}
    .cat-bar-label{display:flex;justify-content:space-between;margin-bottom:6px;font-size:14px;color:var(--text-color,#333)}
    .cat-bar-label span:last-child{font-weight:600;color:#49b1f5}
    .cat-bar-track{height:28px;background:var(--bar-bg,#f0f0f0);border-radius:14px;overflow:hidden;position:relative}
    .cat-bar-fill{height:100%;border-radius:14px;transition:width 1s ease;background:linear-gradient(90deg,#49b1f5,#7ec8f8);position:relative}
    .cat-bar-fill::after{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(180deg,rgba(255,255,255,.3),transparent);border-radius:14px}
    .post-rank-list{width:100%}
    .post-rank-item{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid var(--card-border,#eee);transition:background .2s}
    .post-rank-item:hover{background:var(--hover-bg,#f8f9fa);border-radius:8px}
    .post-rank-item:last-child{border-bottom:none}
    .post-rank-num{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;margin-right:14px;flex-shrink:0}
    .post-rank-num.top1{background:linear-gradient(135deg,#ffd700,#ffb300);color:#fff}
    .post-rank-num.top2{background:linear-gradient(135deg,#c0c0c0,#a0a0a0);color:#fff}
    .post-rank-num.top3{background:linear-gradient(135deg,#cd7f32,#b87333);color:#fff}
    .post-rank-num.normal{background:var(--bar-bg,#f0f0f0);color:var(--text-secondary,#999)}
    .post-rank-info{flex:1;min-width:0}
    .post-rank-title{font-size:15px;color:var(--text-color,#333);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
    .post-rank-views{font-size:14px;font-weight:600;color:#49b1f5;flex-shrink:0;margin-left:12px}
    .stats-updated{text-align:center;color:var(--text-secondary,#999);font-size:13px;margin-top:20px;padding-top:16px;border-top:1px solid var(--card-border,#eee)}
    .stats-updated i{margin-right:4px}
    [data-theme="dark"] .stat-card,.stats-container[data-theme="dark"] .stat-card{background:#1f2937;border-color:#374151}
    [data-theme="dark"] .stats-section,.stats-container[data-theme="dark"] .stats-section{background:#1f2937;border-color:#374151}
    [data-theme="dark"] .stat-card .stat-value,[data-theme="dark"] .stats-section-title,[data-theme="dark"] .post-rank-title,[data-theme="dark"] .cat-bar-label{color:#e5e7eb}
    [data-theme="dark"] .cat-bar-track,[data-theme="dark"] .post-rank-num.normal{background:#374151}
    [data-theme="dark"] .post-rank-item:hover{background:#374151}
    [data-theme="dark"] .stats-updated,[data-theme="dark"] .stat-card .stat-label,[data-theme="dark"] .post-rank-views{color:#9ca3af}
    @media(max-width:768px){.stats-overview{grid-template-columns:repeat(2,1fr);gap:12px}.stat-card{padding:16px}.stat-card .stat-value{font-size:22px}.stats-section{padding:18px}.cat-chart-area{flex-direction:column}}

  .stats-overview
    .stat-card.pv
      .stat-icon
        i.fas.fa-eye
      .stat-value#stat-total-pv --
      .stat-label 总浏览量 (PV)
    .stat-card.uv
      .stat-icon
        i.fas.fa-users
      .stat-value#stat-total-uv --
      .stat-label 总访客数 (UV)
    .stat-card.posts
      .stat-icon
        i.fas.fa-file-alt
      .stat-value#stat-total-posts --
      .stat-label 文章总数
    .stat-card.cats
      .stat-icon
        i.fas.fa-folder-open
      .stat-value#stat-total-cats --
      .stat-label 分类总数

  .stats-section
    .stats-section-title
      i.fas.fa-chart-bar
      | 分类浏览量排行
    .cat-chart-area
      .cat-bar-chart#cat-bar-chart

  .stats-section
    .stats-section-title
      i.fas.fa-trophy
      | 文章浏览量排行
    .post-rank-list#post-rank-list

  .stats-updated
    i.fas.fa-clock
    | 数据更新于：
    span#stat-updated-time --

  script(src="/js/stats-renderer.js")
